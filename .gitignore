# ==============================================================================
# .gitignore for Academic Claude Code Projects
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
.Rdata

# OS files
.DS_Store
Thumbs.db

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Quarto rendering artifacts
/.quarto/

# Output artifacts — uncomment lines below based on your preference
# *.rds
# output/**/*.rds
docs/

# Raw data (too large for git; stored on OneDrive)
data/raw/ewcs/
data/raw/ameco0/
data/raw/ilo_unemployment/
data/raw/arbeitslose-quoten-dlk-0-zip/
data/raw/unemployment/ameco/
data/raw/unemployment/ilo/
data/raw/unemployment/germany_ba/
data/raw/unemployment/eurostat/
data/raw/unemployment/worldbank/
data/raw/alo-zeitreihe-dwo-b-0-xlsx.xlsx
data/raw/ameco_unemployment_rates.csv
data/raw/eurostat_unemployment_rates.csv
data/raw/eurostat_youth_unemployment_rates.csv
data/raw/worldbank_unemployment_rates.csv

# Keep processed unemployment outputs in git (small CSVs)
!data/raw/unemployment/processed/

# Large model objects (regenerate from scripts)
scripts/R/output/**/models_*.rds

# Large cleaned data (regenerate from 05_clean_ewcs.R)
data/cleaned/ewcs_analysis.csv

# Supporting papers (copyrighted)
master_supporting_docs/supporting_papers/
master_supporting_docs/*.xlsx
